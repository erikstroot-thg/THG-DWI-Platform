# Kies je AI provider: "anthropic" of "openai"
AI_PROVIDER=anthropic

# Anthropic Claude API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-jouw-key-hier

# OF: OpenAI API key (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=sk-jouw-key-hier

# Backend poort
PORT=3001
